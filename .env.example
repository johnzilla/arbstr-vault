# Vaultwarden — Agent Treasury Service
# Copy to .env and configure

# Required — admin bearer token for operator endpoints (min 32 chars)
VAULTWARDEN_ADMIN_TOKEN=change-me-to-a-32-char-minimum-secret

# Database
DATABASE_PATH=./vaultwarden.db

# Server
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# Wallet backend: simulated | lightning | cashu | auto
WALLET_BACKEND=simulated

# Lightning (required when WALLET_BACKEND=lightning or auto)
# LND_HOST=127.0.0.1
# LND_PORT=10009
# LND_CERT_BASE64=<base64-encoded TLS cert>
# LND_MACAROON_BASE64=<base64-encoded scoped macaroon>

# Cashu (required when WALLET_BACKEND=cashu or auto)
# CASHU_MINT_URL=http://localhost:3338
# CASHU_THRESHOLD_MSAT=1000000

# Operator webhook notifications (optional)
# OPERATOR_WEBHOOK_URL=https://example.com/webhook
# OPERATOR_WEBHOOK_SECRET=<min 16 chars for HMAC-SHA256 signing>

# Internal service auth (optional — enables /internal/* billing routes)
# VAULT_INTERNAL_TOKEN=<min 32 chars, shared with arbstr core>
